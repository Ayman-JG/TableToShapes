  <ribbon>
    <tabs>
      <tab idMso="TabHome">
        <group id="TableToShapesGroup" label="Table Tools">
          <button id="ConvertTableButton"
                  label="Convert Table to Shapes"
                  size="large"
                  imageMso="TableDrawTable"
                  onAction="OnConvertTableClicked"
                  screentip="Convert the selected table into a pixel-identical group of shapes." />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
